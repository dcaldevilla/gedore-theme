{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_weight = current_variant.weight
  assign longitud_mm = product.metafields.custom.longitud_mm_.value
  assign anchura_mm = product.metafields.custom.anchura_mm_.value
  assign altura_mm = product.metafields.custom.altura_mm_.value

  assign has_dimension_data = false
  if product_weight > 0 or longitud_mm != blank or anchura_mm != blank or altura_mm != blank
    assign has_dimension_data = true
  endif
-%}

{%- if has_dimension_data -%}
  <div class="product__accordion accordion quick-add-hidden">
    <details id="Details-custom-dimensions-{{ section.id }}">
      <summary>
        <div class="summary__title">
          {% render 'icon-accordion', icon: 'ruler' %}
          <h2 class="h4 accordion__title inline-richtext">Peso y dimensiones</h2>
        </div>
        {{- 'icon-caret.svg' | inline_asset_content -}}
      </summary>
      <div class="accordion__content rte" id="ProductAccordion-custom-dimensions-{{ section.id }}">
        <ul>
          {%- if product_weight > 0 -%}
            <li><strong>Peso:</strong> {{ product_weight | weight_with_unit }}</li>
          {%- endif -%}
          {%- if longitud_mm != blank -%}
            <li><strong>Longitud:</strong> {{ longitud_mm }} mm</li>
          {%- endif -%}
          {%- if anchura_mm != blank -%}
            <li><strong>Anchura:</strong> {{ anchura_mm }} mm</li>
          {%- endif -%}
          {%- if altura_mm != blank -%}
            <li><strong>Altura:</strong> {{ altura_mm }} mm</li>
          {%- endif -%}
        </ul>
      </div>
    </details>
  </div>
{%- endif -%}
