{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign mpn = current_variant.metafields['mm-google-shopping'].mpn
  assign ean = current_variant.barcode
-%}

{%- capture identifiers_data -%}
  {
    {%- for variant in product.variants -%}
      "{{ variant.id }}": {
        "mpn": {{ variant.metafields['mm-google-shopping'].mpn | json }},
        "ean": {{ variant.barcode | json }},
        "sku": {{ variant.sku | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  }
{%- endcapture -%}

<div class="custom-product-meta-grid" id="ProductIdentifiers-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="custom-product-meta-grid__item">
    <span class="custom-product-meta-grid__label">SKU</span>
    <p class="custom-product-meta-grid__value" data-product-sku-grid>
      {%- if current_variant.sku != blank -%}
        {{ current_variant.sku }}
      {%- else -%}
        no disponible
      {%- endif -%}
    </p>
  </div>
  <div class="custom-product-meta-grid__item">
    <span class="custom-product-meta-grid__label">MPN</span>
    <p class="custom-product-meta-grid__value" data-product-mpn>
      {%- if mpn != blank -%}
        {{ mpn }}
      {%- else -%}
        no disponible
      {%- endif -%}
    </p>
  </div>
  <div class="custom-product-meta-grid__item">
    <span class="custom-product-meta-grid__label">EAN13</span>
    <p class="custom-product-meta-grid__value" data-product-ean>
      {%- if ean != blank -%}
        {{ ean }}
      {%- else -%}
        no disponible
      {%- endif -%}
    </p>
  </div>
  <div class="custom-product-meta-grid__item">
    <span class="custom-product-meta-grid__label">Stock</span>
    <p class="custom-product-meta-grid__value custom-product-meta-grid__value--muted">Ver disponibilidad por ubicación</p>
  </div>
</div>

<script type="application/json" id="ProductIdentifiersData-{{ section.id }}">
  {{- identifiers_data | strip_newlines -}}
</script>
